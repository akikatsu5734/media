# Claude / Anthropic API
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# WordPress REST API
WP_URL=https://aki-katsu.co.jp/magazine
WP_USERNAME=your_wp_username
WP_APP_PASSWORD=your_wp_application_password
# 任意: デフォルトのWordPressカテゴリID（管理画面で確認）
WP_DEFAULT_CATEGORY_ID=1
# Gemini API（アイキャッチ画像生成に使用）
# Google AI Studio ( https://aistudio.google.com/ ) で発行
GEMINI_API_KEY=your_gemini_api_key_here
# 記事内CTAボタンのリンク先URL（省略時はデフォルト値を使用）
WP_CTA_URL=https://aki-katsu.co.jp/counter/
# Notion 連携（任意: 記事状態管理ダッシュボード）
# セットアップ手順: docs/notion_setup_guide.md を参照
NOTION_API_KEY=secret_your_notion_integration_secret_here
NOTION_ARTICLES_DB_ID=your_notion_articles_database_id_here
